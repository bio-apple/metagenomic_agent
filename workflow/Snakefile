# Params-driven Snakemake handoff — Agent writes snakemake_config.yaml + params.yaml.
# Prefer --configfile from outdir/workflow/snakemake_config.yaml (written by the Agent).

configfile: "config/default.yaml"

INPUT_DIR = config.get("input_dir", "tests/fixtures/fastq")
OUTDIR = config.get("outdir", "results")
MODE = config.get("mode", "mock")
THREADS = int(config.get("threads", 4))
MEMORY_GB = int(config.get("memory_gb", 32))
QUERY = config.get(
    "query",
    "Analyze shotgun metagenomic samples and identify microbial biomarkers.",
)
AGENT_PARAMS = config.get("agent_params", "")


rule all:
    input:
        f"{OUTDIR}/final_report.html",
        f"{OUTDIR}/taxonomy_profile.tsv",
        f"{OUTDIR}/workflow/dag.json",
        f"{OUTDIR}/evidence/evidence_table.md",


rule run_agent:
    """End-to-end LangGraph agent; resources from Agent-emitted YAML (not LLM shell)."""
    output:
        report=f"{OUTDIR}/final_report.html",
        taxonomy=f"{OUTDIR}/taxonomy_profile.tsv",
        quality=f"{OUTDIR}/quality_report.html",
        dag=f"{OUTDIR}/workflow/dag.json",
        evidence=f"{OUTDIR}/evidence/evidence_table.md",
    params:
        input_dir=INPUT_DIR,
        outdir=OUTDIR,
        mode=MODE,
        query=QUERY,
        agent_params=AGENT_PARAMS,
        memory_gb=MEMORY_GB,
    threads: THREADS
    shell:
        """
        # agent_params={params.agent_params} memory_gb={params.memory_gb}
        meta-agent run \
          --input {params.input_dir} \
          --outdir {params.outdir} \
          --mode {params.mode} \
          --query "{params.query}" \
          --yes
        """


rule stage_qc:
    input: rules.run_agent.output.quality
    output: touch(f"{OUTDIR}/.stage_qc")


rule stage_taxonomy:
    input: rules.run_agent.output.taxonomy
    output: touch(f"{OUTDIR}/.stage_taxonomy")


rule stage_differential_evidence:
    input: rules.run_agent.output.evidence
    output: touch(f"{OUTDIR}/.stage_differential_evidence")
